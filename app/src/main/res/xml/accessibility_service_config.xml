<?xml version="1.0" encoding="utf-8"?>
<!--
    无障碍服务配置
    - accessibilityFeedbackType: 反馈类型设为通用
    - accessibilityFlags: flagRetrieveInteractiveWindows 用于获取活跃窗口
                        flagReportViewIds 用于获取视图 ID，方便节点扫描
    - notificationTimeout: 收到事件后的处理超时（毫秒）
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged|typeViewScrolled"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagRetrieveInteractiveWindows|flagReportViewIds"
    android:canRetrieveWindowContent="true"
    android:notificationTimeout="500"
    android:description="@string/accessibility_service_description" />
